{
  "manifest_version": 3,
  "key": "",
  "name": "Save Media",
  "version": "1.1.0",
  "description": "Alt+S / Ctrl+S to save images and videos. LuluStream API integration.",
  "permissions": ["downloads", "nativeMessaging", "storage"],
  "action": { "default_popup": "popup.html" },
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detect.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
